{
  "schema_version": "1.0.0",
  "name": "mobile-autofix-rules",
  "mode": "deterministic-local-safe-fixes",
  "defaults": {
    "apply_requires_explicit_flag": true,
    "write_state": true,
    "no_content_read_for_local_private_helpers": true,
    "no_delete": true,
    "quarantine_instead_of_delete": true
  },
  "rules": [
    {
      "id": "developer-folders",
      "kind": "filesystem",
      "severity": "info",
      "description": "Create required mobile operation folders under ~/Documents/Developer.",
      "action": "ensure_directories"
    },
    {
      "id": "gitignore-local-runtime",
      "kind": "repository-safety",
      "severity": "warn",
      "description": "Ensure local runtime helper files stay ignored by Git.",
      "action": "ensure_gitignore_lines"
    },
    {
      "id": "static-contract",
      "kind": "static-platform",
      "severity": "error",
      "description": "Required static platform files must exist and be non-empty.",
      "action": "check_required_files"
    },
    {
      "id": "spaced-manifest-quarantine",
      "kind": "a-shell-friction",
      "severity": "warn",
      "description": "Move non-canonical spaced manifest copy to quarantine when canonical manifest.webmanifest exists.",
      "action": "quarantine_spaced_manifest"
    },
    {
      "id": "flow-registry-integrity",
      "kind": "control-plane",
      "severity": "error",
      "description": "Flow registry must be valid JSON with unique flow ids and non-empty command arrays.",
      "action": "validate_flows"
    },
    {
      "id": "environment-integrity",
      "kind": "control-plane",
      "severity": "error",
      "description": "Environment registry must be valid JSON with required components and command arrays.",
      "action": "validate_environment"
    }
  ]
}
