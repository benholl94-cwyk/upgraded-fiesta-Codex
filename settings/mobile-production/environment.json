{
  "schema_version": "1.0.0",
  "name": "upgraded-fiesta-mobile-production-control-plane",
  "mode": "iphone_a_shell_control_plane",
  "runtime": "python3_stdlib_only",
  "paths": {
    "developer_root": "~/Documents/Developer",
    "logs": "~/Documents/Developer/logs",
    "runs": "~/Documents/Developer/runs",
    "exports": "~/Documents/Developer/exports",
    "backups": "~/Documents/Developer/backups"
  },
  "components": [
    {
      "id": "platform_validation",
      "kind": "gate",
      "command": ["python3", "scripts/validate_mobile_iphone_platform.py"],
      "required": true
    },
    {
      "id": "mobile_operator",
      "kind": "operator",
      "command": ["python3", "scripts/mobile_operator.py", "doctor"],
      "required": true
    },
    {
      "id": "static_server",
      "kind": "local_service",
      "command": ["python3", "scripts/ashell_static_server.py", "--self-test"],
      "required": true
    },
    {
      "id": "codex_chat",
      "kind": "interactive_ui",
      "command": ["python3", "scripts/ashell_codex_chat.py", "--self-test"],
      "required": true
    },
    {
      "id": "repository_audit",
      "kind": "report",
      "command": ["python3", "scripts/repository_audit_report.py", "--format", "markdown"],
      "required": true
    }
  ],
  "policies": {
    "no_tmp_required": true,
    "no_credentials_in_repository": true,
    "local_first": true,
    "explicit_start_for_long_running_processes": true,
    "portable_ios_filesystem": true
  }
}
