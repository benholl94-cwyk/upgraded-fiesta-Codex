{
  "schema_version": "1.0.0",
  "name": "ashell-codex-cli-agent",
  "mode": "single_interactive_agent_chat",
  "state_file": "~/Documents/Developer/runs/codex-cli-agent-state.json",
  "log_file": "~/Documents/Developer/logs/codex-cli-agent-YYYYMMDD.jsonl",
  "inventory_file": "~/Documents/Developer/exports/repo-byte-inventory-YYYYMMDDTHHMMSS.json",
  "principles": {
    "single_prompt": true,
    "repo_root_execution": true,
    "bridge_command_from_env": "CODEX_CHAT_BRIDGE_CMD",
    "allowlisted_repo_tools": true,
    "no_free_shell_execution": true,
    "local_files_explicit_attach_only": true,
    "external_targets_explicit_policy_only": true,
    "state_and_logs_always_written": true
  },
  "commands": [
    "/help",
    "/status",
    "/inventory",
    "/attach <path>",
    "/plan <task>",
    "/run <task>",
    "/ask <prompt>",
    "/api-plan",
    "/api-probe",
    "/gate",
    "/evidence",
    "/clear",
    "/exit"
  ]
}
