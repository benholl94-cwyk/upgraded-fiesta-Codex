{
  "schema_version": "1.0.0",
  "name": "mobile-local-gates",
  "description": "Neutral gate definitions for a-Shell that keep setup, maintenance and workflow checks separate but composable.",
  "gates": [
    {
      "id": "local-gate",
      "title": "Run local maintenance and orchestration checks",
      "command": ["python3", "scripts/ashell_gate.py"],
      "blocking": true
    },
    {
      "id": "local-gate-with-setup",
      "title": "Run local gate and the existing Codex setup gate",
      "command": ["python3", "scripts/ashell_gate.py", "--with-setup"],
      "blocking": true
    },
    {
      "id": "direct-maintenance-plan",
      "title": "Inspect local maintenance state",
      "command": ["python3", "scripts/ashell_maintain.py", "plan"],
      "blocking": false
    },
    {
      "id": "direct-maintenance-apply",
      "title": "Apply deterministic local maintenance state",
      "command": ["python3", "scripts/ashell_maintain.py", "apply"],
      "blocking": true
    }
  ]
}
