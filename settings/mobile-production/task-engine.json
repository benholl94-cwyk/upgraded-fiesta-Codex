{
  "schema_version": "1.0.0",
  "name": "mobile-task-transmutation-engine",
  "mode": "intent_to_plan_to_validated_action",
  "principles": {
    "allowlisted_commands_only": true,
    "no_free_shell_execution": true,
    "plan_before_run": true,
    "validate_after_run": true,
    "write_evidence": true,
    "repo_root_execution": true
  },
  "state_file": "~/Documents/Developer/runs/mobile-task-engine-state.json",
  "log_file": "~/Documents/Developer/logs/mobile-task-engine-YYYYMMDD.jsonl",
  "export_file": "~/Documents/Developer/exports/mobile-task-report-YYYYMMDDTHHMMSS.json",
  "stages": [
    "intake",
    "context_snapshot",
    "intent_scoring",
    "gap_mapping",
    "plan_synthesis",
    "allowlist_resolution",
    "execution",
    "validation",
    "evidence_export"
  ],
  "fallback_policy": {
    "unknown_intent": "create plan-only report and route to operator prompt note",
    "failed_step": "stop chain, write failure evidence, keep last valid state",
    "long_running_step": "plan only unless explicitly selected as standalone command"
  }
}
