{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:upgraded-fiesta:remote-control:report:v1",
  "title": "upgraded-fiesta remote control consent report",
  "type": "object",
  "required": [
    "schema",
    "generated_at_utc",
    "ok",
    "command",
    "repository",
    "consent",
    "routes",
    "security"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {"const": "upgraded-fiesta.remote-control.report.v1"},
    "generated_at_utc": {"type": "string"},
    "ok": {"type": "boolean"},
    "command": {"type": "string"},
    "repository": {
      "type": "object",
      "required": ["full_name", "default_branch", "known_main_head"],
      "properties": {
        "full_name": {"type": "string"},
        "default_branch": {"type": "string"},
        "known_main_head": {"type": "string", "pattern": "^[a-f0-9]{40}$"}
      }
    },
    "consent": {"type": "object"},
    "routes": {"type": "array"},
    "security": {"type": "object"}
  }
}
