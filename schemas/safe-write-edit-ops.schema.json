{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:upgraded-fiesta:safe-write-edit-ops:v1",
  "title": "upgraded-fiesta safe_write/edit/ops object",
  "type": "object",
  "required": [
    "schema",
    "operation_id",
    "mode",
    "actor",
    "material",
    "ops"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "upgraded-fiesta.safe-write-edit-ops.v1"
    },
    "operation_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 120,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "mode": {
      "enum": [
        "plan",
        "apply"
      ]
    },
    "actor": {
      "type": "object",
      "required": [
        "type",
        "name"
      ],
      "additionalProperties": true,
      "properties": {
        "type": {
          "enum": [
            "assistant",
            "ci",
            "operator"
          ]
        },
        "name": {
          "type": "string"
        }
      }
    },
    "material": {
      "type": "object",
      "description": "Actual values used to justify this object; no placeholders.",
      "additionalProperties": true
    },
    "ops": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "type": "object",
        "required": [
          "op"
        ],
        "additionalProperties": true,
        "properties": {
          "op": {
            "enum": [
              "mkdir",
              "write_file",
              "append_file",
              "edit_replace",
              "copy_file",
              "quarantine_path"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "from_path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "to_path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "overwrite": {
            "type": "boolean"
          },
          "require_hash": {
            "type": "boolean"
          },
          "require_source_hash": {
            "type": "boolean"
          },
          "require_target_hash": {
            "type": "boolean"
          },
          "expected_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "expected_source_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "expected_target_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "content_utf8": {
            "type": "string"
          },
          "content_json": {},
          "replacements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "find",
                "replace"
              ],
              "properties": {
                "find": {
                  "type": "string"
                },
                "replace": {
                  "type": "string"
                },
                "count": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    }
  }
}
