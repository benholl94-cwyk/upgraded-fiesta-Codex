# Copy to .env.signal.local on the Linux/Docker host.
# Do not commit real phone numbers, PINs, captcha tokens, or Signal state files.

SIGNAL_CLI_MODE=json-rpc-native
SIGNAL_BIND_HOST=127.0.0.1
SIGNAL_BIND_PORT=9922
SIGNAL_STATE_DIR=./data/signal-cli

# Optional. Use only if you run normal/native mode and do not receive messages elsewhere.
SIGNAL_AUTO_RECEIVE_SCHEDULE=

# Used by scripts/signal_cli_smoke_test.py
SIGNAL_API_BASE_URL=http://127.0.0.1:9922
SIGNAL_ACCOUNT_NUMBER=+4900000000000
SIGNAL_TEST_RECIPIENT=+4900000000000
